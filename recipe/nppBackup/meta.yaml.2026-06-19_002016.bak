{% set name = "prawcore" %}
{% set import = "prawcore" %}
{% set version = "4.0.0" %}
{% set sha256 = "c7e4d6e1b71e2b9c88680aee467e3e07d22df4c91bb01488ce2a3ab43d76b076" %}

package:
  name: {{ name|lower }}
  version: {{ version }}

source:
  url: https://pypi.org/packages/source/{{ name[0]|lower }}/{{ name|lower }}/{{ name.replace('-', '_') }}-{{ version }}.tar.gz
  sha256: {{ sha256 }}

build:
  noarch: python
  number: 0
  script: {{ PYTHON }} -m pip install . -vv

requirements:
  host:
    - python {{ python_min }}
<<<<<<< HEAD
    - flit-core >=3.12.0,<4
=======
    - hatchling
>>>>>>> 31c139d (Switch from Flit-Core to Hatchling for build backend)
    - pip
  run:
    - python >={{ python_min }}
    - requests >=2.34.2,<3.0

test:
  requires:
    - pip
    - python {{ python_min }}
  commands:
    - pip check
  imports:
    - {{ import }}

about:
  home: https://github.com/praw-dev/prawcore
  license: BSD-2-Clause
  license_family: BSD
  license_file: LICENSE.txt
  summary: Low-level communication layer for PRAW 4+
  description: Prawcore is a low-level communication layer used by PRAW 4+.
  dev_url: https://github.com/praw-dev/prawcore
  doc_url: https://prawcore.readthedocs.io/

extra:
  recipe-maintainers:
    - CAM-Gerlach
    - djsutherland
